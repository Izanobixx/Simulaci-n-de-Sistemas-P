      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"DissolveMembrane", "[", 
      RowBox[{"membrane_", ",", " ", "system_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"s", ",", "newSys", ",", "i", ",", "j", ",", "lower"}], "}"}],
        ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"newSys", " ", "=", " ", 
         RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "IF", " ", "current", " ", "membrane", " ", "IS", " ", "target", 
