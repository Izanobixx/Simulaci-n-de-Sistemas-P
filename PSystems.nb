          RowBox[{
           RowBox[{"Return", "[", "system", "]"}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"foundMembrane", "=", 
         RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "2"}], ",", " ", 
          RowBox[{"i", "<=", 
           RowBox[{"Length", "[", "system", "]"}]}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"IF", " ", "submembrane", " ", "is", " ", "FOUND"}], " ", 
            "->", " ", 
            RowBox[{"recursion", " ", "call"}]}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Length", "[", 
               RowBox[{"system", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", ">", " ", "0"}], 
             ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"foundMembrane", " ", "=", " ", 
               RowBox[{"GetMembrane", "[", 
                RowBox[{"membrane", ",", 
                 RowBox[{"system", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
                RowBox[{
                "IF", " ", "the", " ", "membrane", " ", "has", " ", "been", 
                 " ", "found", " ", "in", " ", "the", " ", "submembrane"}], 
                ",", " ", 
                RowBox[{"RETURN", " ", "it"}]}], "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Length", "[", "foundMembrane", "]"}], ">", "0"}], 
                ",", 
                RowBox[{"Return", "[", "foundMembrane", "]"}]}], "]"}], 
              ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "IF", " ", "all", " ", "submembranes", " ", "have", " ", "been", 
