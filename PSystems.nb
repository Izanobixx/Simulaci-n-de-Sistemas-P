             RowBox[{"system", ",", 
              RowBox[{"FirstPosition", "[", 
               RowBox[{"system", ",", "symbol"}], "]"}]}], "]"}], "]"}], 
           ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
