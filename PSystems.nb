          RowBox[{
           RowBox[{"CHANGE", " ", "membrane_ID", " ", "to"}], " ", "-", 
           RowBox[{"1", " ", "and", " ", "RETURN"}]}]}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"system", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "==", "membrane"}], ",", 
          RowBox[{
           RowBox[{"newSys", " ", "=", " ", "system"}], ";", 
           RowBox[{
            RowBox[{"newSys", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "=", 
            RowBox[{"-", "1"}]}], ";", 
           RowBox[{"Return", "[", "newSys", "]"}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "FOR", " ", "every", " ", "element", " ", "in", " ", "the", " ", 
          "current", " ", "membrane"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "1"}], ",", 
          RowBox[{"i", "<=", 
           RowBox[{"Length", "[", "system", "]"}]}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
            "IF", " ", "current", " ", "element", " ", "is", " ", "the", " ", 
             "membrane_ID", " ", "OR", " ", "a", " ", "symbol"}], ",", " ", 
