           ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "2"}], ",", " ", 
          RowBox[{"i", "<=", 
           RowBox[{"Length", "[", "system", "]"}]}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"IF", " ", "submembrane", " ", "is", " ", "FOUND"}], " ", 
            "->", " ", 
            RowBox[{
            "REPLACE", " ", "submembrane", " ", "with", " ", "recursion", " ",
              "call"}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
