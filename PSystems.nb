     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"newSys", ",", "i"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"newSys", " ", "=", " ", "system"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "IF", " ", "current", " ", "membrane", " ", "IS", " ", "target", 
           " ", "membrane"}], " ", "->", " ", 
          RowBox[{"INSERT", " ", "symbol", " ", "and", " ", "RETURN"}]}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"system", "[", 
            RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", "membrane"}], ",", 
