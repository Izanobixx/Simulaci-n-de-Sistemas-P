Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"--", 
     RowBox[{"-", " ", 
      RowBox[{"MAIN", " ", "--"}]}]}], "-"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Simulate", "[", 
      RowBox[{"P_", ",", " ", "iters_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "system", ",", "newSystem", ",", "allRules", ",", 
         "outputMembraneNumber", ",", "i", ",", "output", ",", 
         "outputMembrane"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"system", "=", 
         RowBox[{"P", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"allRules", "=", 
         RowBox[{"P", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"outputMembraneNumber", "=", 
         RowBox[{"P", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "1"}], ",", 
          RowBox[{"i", "<=", "iters"}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Print", "[", 
            RowBox[{
            "\"\<ITERATION \>\"", ",", " ", "i", ",", " ", 
             "\"\<. System state: \>\"", ",", " ", "system"}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"newSystem", "=", 
            RowBox[{
             RowBox[{"ExecutionCycle", "[", 
              RowBox[{
              "system", ",", "system", ",", "system", ",", "allRules"}], 
              "]"}], "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"system", "==", "newSystem"}], ",", 
             RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"system", "=", "newSystem"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<Exited after \>\"", ",", " ", "i", ",", " ", 
          "\"\< iterations: \>\"", ",", " ", "newSystem"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"output", "=", 
         RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"outputMembrane", " ", "=", " ", 
         RowBox[{"GetMembrane", "[", 
          RowBox[{"outputMembraneNumber", ",", "newSystem"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "2"}], ",", 
          RowBox[{"i", "<=", 
           RowBox[{"Length", "[", "outputMembrane", "]"}]}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Length", "[", 
               RowBox[{"outputMembrane", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "]"}], "==", "0"}], ",", 
             RowBox[{
              RowBox[{"AppendTo", "[", 
               RowBox[{"output", ",", 
                RowBox[{"outputMembrane", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";"}]}], "]"}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<OUTPUT: \>\"", ",", " ", "output"}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
