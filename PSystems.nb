             RowBox[{
              RowBox[{"AppendTo", "[", 
               RowBox[{"newSys", ",", 
                RowBox[{"system", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", "ELSE", "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"lower", " ", "=", " ", 
