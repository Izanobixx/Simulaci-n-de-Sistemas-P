          RowBox[{"RETURN", " ", "EMPTY", " ", "MEMBRANE"}]}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"Return", "[", 
         RowBox[{"{", "}"}], "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ContainsAllSymbols", "[", 
      RowBox[{"symbols_", ",", "required_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
